# Credenciais do único usuário (single-user MVP).
# Para gerar o hash bcrypt da senha:
#   node -e "console.log(require('bcryptjs').hashSync('SUA_SENHA', 12))"
AUTH_USERNAME=eduardo.tavares
AUTH_PASSWORD_HASH=$2b$12$EXEMPLO_substitua_pelo_hash_gerado
AUTH_USER_NAME=Nome Completo
AUTH_USER_ROLE=Preparador Físico

# Chave de assinatura do JWT — 48+ bytes aleatórios em hex.
# Para gerar:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=substitua_por_uma_chave_aleatoria_longa
JWT_EXPIRES_IN_HOURS=12

# Origem permitida pelo CORS. Use * em dev; em produção use o domínio do frontend.
CORS_ORIGIN=*
